# 复制本文件为 web/.env.local（与 web/package.json 同级），填入 Firebase 控制台「项目设置 → 您的应用」里 Web 应用的配置值。
# 切勿把 .env.local 提交到 Git。

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 顾客端「想定制自己的店」展示的联系方式（单行；若要换行可写 \\n）
# VITE_CUSTOM_SHOP_CONTACT=微信：xxx  电话：+60xxxxxxxx
